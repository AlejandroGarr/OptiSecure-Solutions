<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Fecha_caducada</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(Fecha_de_cobro__c)),
  Fecha_de_cobro__c &lt;= TODAY()
)</errorConditionFormula>
    <errorMessage>La fecha de cobro debe ser superior a la fecha actual.</errorMessage>
</ValidationRule>
