<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Emitida</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Estado__c, &quot;Emitida&quot;),
  ISCHANGED(Estado__c)
)</errorConditionFormula>
    <errorMessage>Una vez que la factura esté en estado emitida, no puede ser modificada.</errorMessage>
</ValidationRule>
