<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>parte2</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Etapa__c, &quot;Cerrada - Ganada&quot;),
  ISCHANGED(Etapa__c)
)</errorConditionFormula>
    <errorMessage>Una vez que la oportunidad esté en estado &apos;Cerrada - Ganada&apos;, no puede ser modificada.</errorMessage>
</ValidationRule>
