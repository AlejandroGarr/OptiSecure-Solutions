<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>verific</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Etapa__c, &quot;Cerrada - Perdida&quot;),
  ISBLANK(MotivoPerdida__c)
)</errorConditionFormula>
    <errorMessage>Debe indicar el motivo de pérdida cuando la etapa sea Cerrada - Perdida.</errorMessage>
</ValidationRule>
