        function clearControllerError() {
            var el = document.getElementById('controller-error');
            if (!el) return;

            // Ocultar y vaciar el texto visible
            el.style.display = 'none';
            el.textContent = '';
        }

        function validateNameStep() {
            return emailInput.value.trim().length > 0;
        }

        // --- STEP 4 & 6: OTP ---
        function validateOtpStep(inputs) {
            let all = true;
            inputs.forEach(i => { if (!i.value) all = false; });
            return all;
        }

        function setupOtpLogic(inputs) {
            inputs.forEach((input, index) => {
                input.addEventListener('input', (e) => {
                    e.target.value = e.target.value.replace(/[^0-9]/g, '');
                    if (e.target.value) {
                        e.target.classList.add('filled');
                        if (index < inputs.length - 1) inputs[index + 1].focus();
                    } else {
                        e.target.classList.remove('filled');
                    }
                    validateCurrentStep();
                });
                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Backspace' && !e.target.value && index > 0) inputs[index - 1].focus();
                });
                input.addEventListener('paste', (e) => {
                    e.preventDefault();
                    const data = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '').split('');
                    if (data.length) {
                        inputs.forEach((inp, idx) => {
                            if (data[idx]) { inp.value = data[idx]; inp.classList.add('filled'); }
                        });
                        const focusIdx = Math.min(data.length, inputs.length - 1);
                        inputs[focusIdx].focus();
                        validateCurrentStep();
                    }
                });
            });
        }
        setupOtpLogic(otpEmailInputs);
        setupOtpLogic(otpSmsInputs);

        // Timer Logic
        function startTimer(type) {
            let timeLeft = 29;
            const textEl = type === 'email' ? timerEmailText : timerSmsText;
            const timeValEl = type === 'email' ? document.getElementById('email-time-val') : document.getElementById('sms-time-val');
            const btn = type === 'email' ? btnResendEmail : btnResendSms;

            // Reset UI
            textEl.style.display = 'inline-block';
            btn.style.display = 'none';
            timeValEl.textContent = timeLeft;

            const interval = setInterval(() => {
                timeLeft--;
                timeValEl.textContent = timeLeft;
                if (timeLeft <= 0) {
                    clearInterval(interval);
                    textEl.style.display = 'none';
                    btn.style.display = 'inline-block';
                }
            }, 1000);
        }

        [btnResendEmail, btnResendSms].forEach(btn => btn.addEventListener('click', () => {
            // Resetear contador de intentos al solicitar nuevo código
            verificationAttempts = 0;
            // Limpiar el mensaje de error si existe
            var otpErrorElement = document.getElementById('otp-error');
            if (otpErrorElement) {
                otpErrorElement.style.display = 'none';
                otpErrorElement.textContent = '';
            }
            if (currentStep === 2) {
                var myEmailParam = document.querySelector('[id$="inputEmail"]');
                resendCodEmail(myEmailParam);
            } else if (currentStep === 4) {
                var myPhoneParam = document.querySelector('[id$="inputPhone2"]');
                resendCodSms(myPhoneParam);
            }
        }));

        // --- STEP 5: PHONE ---
        const mobileRegex = /^[67][0-9]{8}$/;
        function validatePhoneStep() {
            const valid = mobileRegex.test(phoneInput.value);
            if (valid) {
                phoneWrapper.classList.remove('error');
                document.getElementById('phone-error').style.display = 'none';
            } else if (phoneInput.value.length > 0) {
                phoneWrapper.classList.add('error');
                document.getElementById('phone-error').style.display = 'flex';
            } else {
                phoneWrapper.classList.remove('error');
                document.getElementById('phone-error').style.display = 'none';
            }
            return valid;
        }
        phoneInput.addEventListener('input', (e) => {
            e.target.value = e.target.value.replace(/[^0-9]/g, '');
            validateCurrentStep();
        });

        // Init
        updateStepUI();
    </script>

