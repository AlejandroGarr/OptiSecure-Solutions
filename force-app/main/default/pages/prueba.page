                currentStep = 3;
                updateStepUI();
                }
            } else {
                showVerificationError(tipo);
                // Si hay error, habilitar el botón de nuevo para que pueda corregir
                btnPage1.disabled = false;
                // Desplazar hacia arriba para ver el mensaje de error
                window.scrollTo({ top: 0, behavior: 'smooth' });

                 if((currentStep===3 && initStep!==3) || (currentStep===4 && totalSteps===4)) {
                    currentStep--;
                    updateStepUI();
                }
            }
        }

        function showVerificationError(tipo) {
            // Detectar si hay errorMessage y abrir modal automáticamente
            var errorMessageElement = document.getElementById('controller-error');
            var headMessageElement = document.getElementById('controller-phone-error');
            var errorText = errorMessageElement.textContent.trim();
            var headText = headMessageElement.textContent.trim();
            
            if (errorText) {
                if(tipo === 'phone'){
                    // Ocultar el mensaje de error original
                    errorMessageElement.style.display = 'none';
                    // Abrir modal genérico con el mensaje de error
                    openGenericModal({
                        headerColor: '#FDE8E4',
                        title: headText!== '' ? headText : 'ERROR DE VALIDACIÓN',
                        message: errorText,
                        iconType: 'warning',
                        iconColor: '#A83226',
                        buttons: [
                            {
                                text: 'Entendido',
                                type: 'primary',
                                onClick: function() {
                                    console.log('Error modal cerrado');
                                }
                            }
                        ]
                    });
                    errorMessageElement.textContent = '';
                } else {
                    var btnPage1 = document.getElementById('nextBtn');
                    btnPage1.textContent = 'Siguiente';
                    verificationAttempts++;

                    // Calcular intentos restantes
                    var remainingAttempts = maxAttempts - verificationAttempts;
                    if (remainingAttempts >= 0) {
                    // Ocultar el mensaje de error original
                    errorMessageElement.style.display = 'none';
                    
                    // Crear o actualizar el elemento de error debajo del otp-container
                    var otpErrorElement = document.getElementById('otp-error');
                    if (!otpErrorElement) {
                        otpErrorElement = document.createElement('div');
                        otpErrorElement.id = 'otp-error';
                        otpErrorElement.style.color = '#A83226';
                        otpErrorElement.style.fontSize = '14px';
                        otpErrorElement.style.marginTop = '12px';
                        otpErrorElement.style.textAlign = 'center';
                        
                        if(tipo === 'email'){
                           otpEmailContainer.parentNode.insertBefore(otpErrorElement, otpEmailContainer.nextSibling);
                        } else{
                           otpSmsContainer.parentNode.insertBefore(otpErrorElement, otpSmsContainer.nextSibling);
                        }
                        
                    }
                    
                    // Construir mensaje según intentos restantes
                    var errorMessage = '';
                    if (remainingAttempts > 0) {
                        var intentosTexto = remainingAttempts === 1 ? 'intento' : 'intentos';
                        errorMessage = 'El código introducido no es correcto. Por seguridad, tienes ' + remainingAttempts + ' ' + intentosTexto + ' más.';
                    } else {
                        errorMessage = 'Has alcanzado el máximo de intentos. Por favor, solicita un nuevo código.';
                        // Deshabilitar el botón de siguiente si se acabaron los intentos
                        btnPage1.disabled = true;
                        nextBtn.classList.remove('active');
                    }
                    
                    otpErrorElement.textContent = errorMessage;
                    otpErrorElement.style.display = 'block';
                    
                    errorMessageElement.textContent = '';
                    }
                }

            }
        }
        
