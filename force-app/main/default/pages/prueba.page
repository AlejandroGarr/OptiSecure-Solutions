                    --color-red-nexho-50: #ffe7e5;
                    --color-red-nexho-100: #ffa295;
                    --color-red-nexho-200: #ff7669;
                    --color-red-nexho-300: #f54b41;
                    --color-red-nexho-400: #d8181b;
                    --color-red-nexho-500: #b90003;
                    --color-red-nexho-600: #920000;
                    --color-red-nexho-700: #680004;
                    --color-green-100: #d7f7dc;
                    --color-green-200: #b8f3c5;
                    --color-green-300: #a0e9b9;
                    --color-green-400: #7fce9a;
                    --color-green-500: #58a275;
