        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{!$Label.msmIdpVerificationMethodTitle}</title>
        <link rel="shortcut icon" href="{!$Resource.FaviconSite}" type="image/x-icon"/>
        <style>
            @font-face {
