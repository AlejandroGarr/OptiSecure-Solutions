        // --- SVG TEMPLATES ---
        const iconX = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>`;
        const iconCheck = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>`;

        // --- NAVIGATION LOGIC ---
        function updateStepUI() {
            // Hide all
            sections.forEach(sec => sec.classList.remove('active'));
            // Show current
            document.getElementById(`step-${currentStep}`).classList.add('active');

            // Progress Bar - 2 steps: 50% para email (steps 1-2), 100% para teléfono (steps 3-4)
            if (progressBarFill) {
                let progressPercent = 0;
                if (currentStep === 1 || currentStep === 2) {
                    progressPercent = 50; // Verificando email
                } else if (currentStep === 3 || currentStep === 4) {
                    progressPercent = 100; // Verificando teléfono
                }
                progressBarFill.style.width = progressPercent + '%';
            }
            
            // Check Validation for current step immediately to set button state
            validateCurrentStep();
            
            // Dynamic Button Text
            if (currentStep === 1) {
                nextBtn.textContent = "Enviar código";
                //nextBtn.disabled = "false";
            } else {
                nextBtn.textContent = "Verificar código";
            }
            if (currentStep === 2) {
                if(btnResendEmail.style.display!=='none')
                {
                    startTimer('email');

                }
                
            }
            if (currentStep === 4) {
                if(btnResendSms.style.display!=='none')
                {
                    startTimer('sms');

                }
                
            }
        }

        nextBtn.addEventListener('click', () => {
            if (nextBtn.disabled) return;
            
            if (currentStep <= totalSteps) {
                if (currentStep === 1) {
                    sendEmailProceed();
                }
                if (currentStep === 2) {
                    verifyEmailAndProceed();
                }
                if (currentStep === 3) {
                    sendSmsProceed();
                } 
                if (currentStep === 4) {
                    verifyCodePhoneProceed();
                } else if (currentStep < totalSteps) {
                    console.log('contador de paso');
                    currentStep++;
                    //TODO: Revisar para controlar método asincrono de verificación - oncomplete
                    if((currentStep===3 && initStep!==3) || (currentStep===4 && totalSteps===4)) {
                        let contador = 1;
                        const interval = setInterval(() => {
                        contador++;
                            if (contador > 5) {
                            updateStepUI();
                            clearInterval(interval);
                            }
                        }, 200);
                    } else {
                        updateStepUI();
                    }
                } 
            }
        });

        backBtn.addEventListener('click', () => {
            if (currentStep === initStep) {
                const params = new URLSearchParams(window.location.search);
                window.location.href = params.get("retUrl");
                //history.back(); // Browser back
            } else {
                currentStep--;
                updateStepUI();
            }
        });

        // --- VALIDATION CONTROLLER ---
        function validateCurrentStep() {

            let isValid = false;
            let isValidCodEmail = false;
            let isValidPhone = false;
            let isValidNif = false;
            let isValidPhoneVerificar = false;
            switch (currentStep) {
                case 1: isValid = validateNameStep(); break;
                case 2: isValidCodEmail = validateOtpStep(otpEmailInputs); break;
                case 3: isValidPhone = validatePhoneStep(); break;
                case 4: isValidPhoneVerificar = validateOtpStep(otpSmsInputs); break;
            }
            if(isValid && currentStep ===1) {
                nextBtn.classList.add('active');
                nextBtn.disabled = false;
            } else if (currentStep ===1) {
                nextBtn.classList.remove('active');
                nextBtn.disabled = true;
            } else if (isValidCodEmail && currentStep ===2) {
                var emailCode = document.querySelector('[id$="emailCode"]');
                emailCode.value = otpEmailInputs[0].value + otpEmailInputs[1].value + otpEmailInputs[2].value + otpEmailInputs[3].value + otpEmailInputs[4].value + otpEmailInputs[5].value;
                nextBtn.classList.add('active');
                nextBtn.disabled = false;
            } else if (currentStep ===2) {
                nextBtn.classList.remove('active');
                nextBtn.disabled = true;
            } else if (isValidPhone && currentStep ===3) {
                var phoneInput = document.querySelector('[id$="phoneInput"]');
                var phoneInput2 = document.querySelector('[id$="phoneInput2"]');
                nextBtn.classList.add('active');
                nextBtn.disabled = false;

            } else if (currentStep ===3) {
                //code before the pause
                nextBtn.classList.remove('active');
                nextBtn.disabled = true;
            } else if (isValidPhoneVerificar && currentStep ===4) {
                var myCodePhoneParam = document.querySelector('[id$="myCode"]');
                myCodePhoneParam.value = otpSmsInputs[0].value + otpSmsInputs[1].value + otpSmsInputs[2].value + otpSmsInputs[3].value + otpSmsInputs[4].value + otpSmsInputs[5].value;
                nextBtn.classList.add('active');
                nextBtn.disabled = false;
            } else if (currentStep ===4) {
                nextBtn.classList.remove('active');
                nextBtn.disabled = true;
            }
        }

        // --- STEP 1: EMAIL ---
        const isValidEmail = (email) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.toLowerCase());
