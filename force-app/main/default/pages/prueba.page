            </div>

            <h2 class="right-title">
                LA PLATAFORMA<br/>
                DONDE LA<br/>
                HOSTELERÍA SE<br/>
                TRANSFORMA
            </h2>
        </div>
    </aside>
    <script>
        // --- MASTER STATE ---
        let currentStep = {!currentStep};
        const totalSteps = {!totalSteps};
        const initStep = {!initStep};
        const originCashboost = {!originCashboost};
        const maxAttempts = 3;
        let verificationAttempts = 0;
        let userData = {
            email: '',
            password: '',
            name: '',
            surname: '',
            phone: '',
            nif: ''
        };

        // --- DOM ELEMENTS ---
        const sections = document.querySelectorAll('.step-section');
        const nextBtn = document.getElementById('nextBtn');
        const backBtn = document.getElementById('backBtn');
        const progressBarFill = document.getElementById('progressBarFill');

        // Step 3: Name
        const emailInput = document.getElementById('email');
        //const phoneInput = document.querySelector('[id$=mobilephone]');

        // Step 4: Verify Code (Email)
        const otpEmailContainer = document.getElementById('otp-email-container');
        const otpEmailInputs = otpEmailContainer.querySelectorAll('.otp-input');
        const displayEmail = document.getElementById('display-email');
        const timerEmailText = document.getElementById('email-timer-text');
        const btnResendEmail = document.getElementById('btn-resend-email');

        // Step 5: Phone
        //const phoneInput = document.getElementById('phone');
        const phoneWrapper = document.getElementById('phone-wrapper');
        const phoneInput = document.querySelector('[id$=inputPhone2]');

