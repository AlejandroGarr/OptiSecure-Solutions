                :root {
                    /* COLORS */
                    --red-main: #D3131D;
                    --red-dark: #b50e18;
                    --grey-border: #808080;
                    --grey-text: #222222;
                    --bg-body: #f2f2f2;
                    --bg-white: #ffffff;
                    --color-black: #000000;
                    --color-white: #ffffff;
                    --color-error: #D3131D;
                    --color-success: #008751;

                    /* FONTS */
                    --font-main: ALTRiviera;
                    --font-weight-regular: 400;
                    --font-weight-medium: 500;
                    --font-weight-bold: 700;
                    --font-weight-extra-bold: 800;

                    /* SIZES */
                    --radius-input: 12px;
                    --radius-btn: 12px;
                    --spacing-standard: 24px;

                    --font-main: ALTRiviera;
                    --radius-btn: 10px;
                    --color-red-700: #D3131D;
                    --color-white: #ffffff;
