        // Función callback que se ejecuta después de la verificación del email
        function handleVerificationResult(isValid, tipo) {
            var btnPage1 = document.getElementById('nextBtn');
            btnPage1.textContent = 'Siguiente';
            
            // Convertir a booleano si viene como string
            var isValidBool = (isValid === 'true' || isValid === true);
            if (isValidBool ) {
                if(tipo === 'phone'){
                    return;
                }
                var modalText = 'Volver a Mi Perfil';
                var modalMessage = 'Ya puedes seguir disfrutando de Nexho®';
                verificationAttempts = 0;
                if(currentStep === totalSteps){
                    var modalTitle = currentStep === 2 ? 'EMAIL VERIFICADO' : 'TELÉFONO VERIFICADO';
                    if(originCashboost){
                        modalText = 'Volver al regalo';
                        modalMessage = 'Tu correo electrónico ha sido verificado correctamente.';
                        modalTitle = 'CORRREO ELECTRÓNICO VALIDADO';
                    }
                    openGenericModal({
                            fullscreen: true,
                            headerColor: '#E8F5E9',
                            title: modalTitle,
                            message: modalMessage,
                            iconType: 'success',
                            iconColor: '#2E7D32',
                            buttons: [
                                {
                                    text: modalText,
                                    type: 'primary',
                                    onClick: function() {
                                        if(totalSteps === currentStep){
                                            window.location.href = document.querySelector('[id$="goBack"]').value;
                                        }
